pipeline {
    agent any
    
    environment {
        BUILD_VERSION="1.0"
    }
    
    tools{
        jdk 'java17Home'
    }
    
    triggers {
        pollSCM('H/5 * * * *')
    }

    stages {
        stage('Clone Repository') {
            steps {
                script {
                    def workspace = env.WORKSPACE
                    def cloneJava= "${workspace}\\cloneJava"

                    // Delete old repo if exists
                    if (fileExists(cloneJava)) {
                        bat "rmdir /S /Q \"${cloneJava}\""
                        echo "Removed existing Repo folder."
                    }
                    
                    bat "mkdir cloneJava"
                    bat "git clone https://github.com/kaverikadamm/Practical4.git \"${workspace}\\cloneJava\""
                }
            }
        }

        stage('Compile Java Program') {
            steps {
                script{
                    bat """
                    echo Compiling Java Program
                    cd cloneJava
                    javac HelloWorld.java
                    """
                }
            }
        }

        stage('Run Java Program') {
            steps {
                script{
                    bat """
                    echo Running Java Program...
                    cd cloneJava
                    java HelloWorld
                    """
                }
            }
        }
    }
}
