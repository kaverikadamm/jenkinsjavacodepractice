pipeline{
    agent any
    
    environment{
        BUILD_VERSION="1.0"
    }
    
    tools{
        jdk'java17Home'
    }
    triggers{
        pollSCM('H/5 * * * *')
    }
    
    stages{
        stage('Clone Repository'){
            steps{
                script{
                    def workspace=env.WORKSPACE
                    def cloneJava="${workspace}\\cloneJava"
                    
                    if(fileExists(cloneJava)){
                        bat "rmdir /S/Q \"${cloneJava}\""
                        echo "Delete existing folder"
                    }
                    
                    bat "mkdir cloneJava"
                    bat "git clone https://github.com/kaverikadamm/jenkinsjavacodepractice.git \"${workspace}\\cloneJava\""
                }
            }
        }
        
        stage("Compile Java program"){
            steps{
                script{
                    bat"""
                    echo compiling java program...
                    cd cloneJava
                    javac HelloWorld.java
                    """
                }
            }
        }
        stage("Run java program"){
            steps{
                script{
                    bat"""
                    echo running java program...
                    cd cloneJava
                    java HelloWorld
                    """
                }
            }
        }
    }
}
